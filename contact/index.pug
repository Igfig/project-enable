extends ../templates/layout.pug

block title
        title Contact | Project ENABLE | The Diné-English Biology Dictionary

block content
    main.contact.text-page
        h2 Contact Us
        p If you have any questions, comments, or suggestions, please reach out to us!

        div.contact-tiles
            a.button.contact-tile(href="mailto:EnableBiology@gmail.com")
                img.icon(src="/assets/img/envelope.svg" alt="Email")
                span EnableBiology@gmail.com
            a.button.contact-tile(href="https://twitter.com/ENABLE_Biology")
                img.icon(src="/assets/img/twitter.svg" alt="Twitter")
                span @ENABLE_Biology
            a.button.contact-tile(href="https://navajobiology.square.site/")
                img.icon(src="/assets/img/dollar-sign.svg" alt="")
                span Donate
